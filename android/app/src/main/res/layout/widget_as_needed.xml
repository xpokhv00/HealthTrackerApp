<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:id="@+id/widget_root_as_needed"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:padding="14dp"
              android:background="@drawable/widget_bg_white">

    <!-- Header -->
    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instant Relief Panel"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="#111827"
            android:layout_marginBottom="10dp" />

    <!-- READY section -->
    <LinearLayout
            android:id="@+id/section_ready"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="READY"
                android:textStyle="bold"
                android:textSize="10sp"
                android:textColor="#27AE60"
                android:letterSpacing="0.08"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/widget_bg_green_header" />

        <AdapterViewFlipper
                android:id="@+id/ready_flipper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:flipInterval="0"
                android:autoStart="false" />

        <!-- Dot indicators for ready pages -->
        <TextView
                android:id="@+id/ready_dots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="8sp"
                android:textColor="#27AE60"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

    </LinearLayout>

    <!-- ON COOLDOWN section -->
    <LinearLayout
            android:id="@+id/section_cooldown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ON COOLDOWN"
                android:textStyle="bold"
                android:textSize="10sp"
                android:textColor="#667085"
                android:letterSpacing="0.08"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/widget_bg_grey_section" />

        <AdapterViewFlipper
                android:id="@+id/cooldown_flipper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:flipInterval="0"
                android:autoStart="false" />

        <!-- Dot indicators for cooldown pages -->
        <TextView
                android:id="@+id/cooldown_dots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="8sp"
                android:textColor="#667085"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
