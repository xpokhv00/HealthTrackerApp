<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:id="@+id/widget_root_routine"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:padding="16dp"
              android:background="@drawable/widget_bg_white">

    <!-- Header -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Meds Timeline"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="#111827" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textStyle="bold"
                android:textSize="10sp"
                android:textColor="#6B7280"
                android:letterSpacing="0.08" />

    </LinearLayout>

    <!-- Empty state -->
    <TextView
            android:id="@+id/section_empty"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center"
            android:text="Open the app to sync your medications"
            android:textSize="13sp"
            android:textColor="#9CA3AF"
            android:visibility="gone" />

    <!-- SECTION: ACTION REQUIRED (missed) -->
    <LinearLayout
            android:id="@+id/section_action_required"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/widget_bg_salmon"
            android:visibility="gone">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTION REQUIRED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#CC4A1A"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                <TextView
                        android:id="@+id/missed_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#111827" />

                <TextView
                        android:id="@+id/missed_meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginTop="3dp" />
            </LinearLayout>

            <TextView
                    android:id="@+id/btn_rescue"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.04"
                    android:text="TAKE NOW"
                    android:background="@drawable/widget_btn_orange" />
        </LinearLayout>
    </LinearLayout>

    <!-- SECTION: NEXT UP (pending) -->
    <LinearLayout
            android:id="@+id/section_next_up"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/widget_bg_blue_section"
            android:visibility="gone">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEXT UP"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#4C7EFF"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

        <!-- Name + button row -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                <TextView
                        android:id="@+id/next_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#111827" />

                <TextView
                        android:id="@+id/next_meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginTop="3dp" />
            </LinearLayout>

            <TextView
                    android:id="@+id/btn_take_next"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.04"
                    android:background="@drawable/widget_btn_blue" />
        </LinearLayout>

        <!-- Progress row — sits below name/button, fixed width with padding -->
        <ProgressBar
                android:id="@+id/next_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:progressDrawable="@drawable/widget_next_progress_bar"
                android:max="100"
                android:progress="0" />

        <!-- Hidden countdown — kept for provider compat, not visible -->
        <TextView
                android:id="@+id/next_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
    </LinearLayout>

    <!-- SECTION: DONE TODAY -->
    <LinearLayout
            android:id="@+id/section_done_today"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/widget_bg_green_section"
            android:visibility="gone">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DONE TODAY"
                    android:textStyle="bold"
                    android:textSize="10sp"
                    android:textColor="#027A48"
                    android:letterSpacing="0.08" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="13sp"
                    android:textColor="#027A48" />
        </LinearLayout>

        <ListView
                android:id="@+id/done_list"
                android:layout_width="match_parent"
                android:layout_height="108dp"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:scrollbars="none" />

        <ListView
                android:id="@+id/done_list_tall"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:scrollbars="none"
                android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
