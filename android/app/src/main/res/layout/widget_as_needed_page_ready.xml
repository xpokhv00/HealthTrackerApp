<?xml version="1.0" encoding="utf-8"?>
<!-- One flipper page: two ready cards side by side -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal">

    <LinearLayout
            android:id="@+id/ready_card_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/widget_card_white"
            android:layout_marginEnd="4dp"
            android:visibility="invisible">

        <TextView
                android:id="@+id/ready_name_a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#111827"
                android:gravity="center"
                android:layout_marginBottom="2dp" />

        <TextView
                android:id="@+id/ready_meta_a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#667085"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

        <TextView
                android:id="@+id/ready_btn_a"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:text="TAKE NOW"
                android:background="@drawable/widget_btn_green" />
    </LinearLayout>

    <LinearLayout
            android:id="@+id/ready_card_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/widget_card_white"
            android:layout_marginStart="4dp"
            android:visibility="invisible">

        <TextView
                android:id="@+id/ready_name_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#111827"
                android:gravity="center"
                android:layout_marginBottom="2dp" />

        <TextView
                android:id="@+id/ready_meta_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#667085"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

        <TextView
                android:id="@+id/ready_btn_b"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:text="TAKE NOW"
                android:background="@drawable/widget_btn_green" />
    </LinearLayout>

</LinearLayout>
