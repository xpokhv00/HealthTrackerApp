<?xml version="1.0" encoding="utf-8"?>
<!-- One flipper page: two cooldown cards side by side -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal">

    <LinearLayout
            android:id="@+id/cooldown_card_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center_horizontal"
            android:background="@drawable/widget_card_white"
            android:layout_marginEnd="4dp"
            android:visibility="invisible">

        <TextView
                android:id="@+id/cooldown_name_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

        <!-- Progress ring with centered time text -->
        <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="6dp">

            <ProgressBar
                    android:id="@+id/cooldown_progress_a"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:progressDrawable="@drawable/widget_cooldown_progress_ring"
                    android:max="100"
                    android:progress="0" />

            <TextView
                    android:id="@+id/cooldown_timer_a"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#667085" />

        </FrameLayout>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:text="TAKE"
                android:background="@drawable/widget_btn_disabled" />
    </LinearLayout>

    <LinearLayout
            android:id="@+id/cooldown_card_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center_horizontal"
            android:background="@drawable/widget_card_white"
            android:layout_marginStart="4dp"
            android:visibility="invisible">

        <TextView
                android:id="@+id/cooldown_name_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

        <!-- Progress ring with centered time text -->
        <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="6dp">

            <ProgressBar
                    android:id="@+id/cooldown_progress_b"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:progressDrawable="@drawable/widget_cooldown_progress_ring"
                    android:max="100"
                    android:progress="0" />

            <TextView
                    android:id="@+id/cooldown_timer_b"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#667085" />

        </FrameLayout>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:text="TAKE"
                android:background="@drawable/widget_btn_disabled" />
    </LinearLayout>

</LinearLayout>
