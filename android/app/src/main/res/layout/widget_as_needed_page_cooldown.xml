<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal">

    <LinearLayout
            android:id="@+id/cooldown_card_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/widget_card_white"
            android:layout_marginEnd="4dp"
            android:visibility="invisible">

        <TextView
                android:id="@+id/cooldown_name_a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

        <ProgressBar
                android:id="@+id/cooldown_progress_a"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginBottom="8dp"
                android:progressDrawable="@drawable/widget_cooldown_progress_bar"
                android:max="100"
                android:progress="0" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AVAILABLE IN"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="2dp" />

        <TextView
                android:id="@+id/cooldown_timer_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#F79009"
                android:gravity="center"
                android:layout_gravity="center_horizontal" />

    </LinearLayout>

    <LinearLayout
            android:id="@+id/cooldown_card_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/widget_card_white"
            android:layout_marginStart="4dp"
            android:visibility="invisible">

        <TextView
                android:id="@+id/cooldown_name_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#374151"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

        <ProgressBar
                android:id="@+id/cooldown_progress_b"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginBottom="8dp"
                android:progressDrawable="@drawable/widget_cooldown_progress_bar"
                android:max="100"
                android:progress="0" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AVAILABLE IN"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="2dp" />

        <TextView
                android:id="@+id/cooldown_timer_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#F79009"
                android:gravity="center"
                android:layout_gravity="center_horizontal" />

    </LinearLayout>

</LinearLayout>
