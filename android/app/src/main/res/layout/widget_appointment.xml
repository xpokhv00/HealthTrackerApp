<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:id="@+id/widget_root_appointment"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:padding="16dp"
              android:background="@drawable/widget_bg_white">

    <!-- ROW 1: Urgency pill + CTA — equal height via minHeight + match_parent -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

        <!-- Urgency pill -->
        <TextView
                android:id="@+id/appt_urgency_pill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minHeight="36dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:background="@drawable/widget_appt_pill_distant"
                android:textColor="#344054"
                android:text="NEXT APPOINTMENT" />

        <!-- CTA button -->
        <TextView
                android:id="@+id/appt_cta_zone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:minHeight="36dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/widget_appt_cta_bg"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.05"
                android:text="PREPARE LIST" />
    </LinearLayout>

    <!-- ROW 2: Hero block -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

        <TextView
                android:id="@+id/appt_hero_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:text="DR. NOVAK" />

        <TextView
                android:id="@+id/appt_hero_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="13sp"
                android:textColor="#667085"
                android:text="General Practitioner · City Clinic" />
    </LinearLayout>

    <!-- ROW 3: Prep checklist (vertical) -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
                android:id="@+id/chip_symptoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/widget_appt_chip_pending"
                android:textColor="#344054"
                android:text="&#9744;  SYMPTOMS" />

        <TextView
                android:id="@+id/chip_meds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/widget_appt_chip_pending"
                android:textColor="#344054"
                android:text="&#9744;  MEDS LIST" />

        <TextView
                android:id="@+id/chip_report"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/widget_appt_chip_pending"
                android:textColor="#344054"
                android:text="&#9744;  BLOOD REPORT" />
    </LinearLayout>

</LinearLayout>
