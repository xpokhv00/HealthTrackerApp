<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:id="@+id/widget_root_appointment"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:padding="16dp"
              android:background="@drawable/widget_bg_dark">

    <!-- ROW 1: Urgency pill + CTA -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

        <TextView
                android:id="@+id/appt_urgency_pill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:minHeight="36dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.07"
                android:background="@drawable/widget_appt_pill_distant"
                android:textColor="#94A3B8"
                android:text="NEXT APPOINTMENT" />

        <TextView
                android:id="@+id/appt_cta_zone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:minHeight="36dp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/widget_appt_cta_bg"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.06"
                android:text="PREPARE LIST" />
    </LinearLayout>

    <!-- ROW 2: Hero block -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp">

        <TextView
                android:id="@+id/appt_hero_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F8FAFC"
                android:letterSpacing="0.01"
                android:text="DR. NOVAK" />

        <TextView
                android:id="@+id/appt_hero_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#60A5FA"
                android:text="Sunday · 10:00 AM" />

        <TextView
                android:id="@+id/appt_hero_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:text="General Practitioner · City Clinic" />
    </LinearLayout>

    <!-- Divider -->
    <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#1E293B"
            android:text="" />

    <!-- ROW 3: Prep checklist label -->
    <TextView
            android:id="@+id/appt_checklist_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="#475569"
            android:text="PREPARATION CHECKLIST" />

    <!-- ROW 3: Prep checklist items -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
                android:id="@+id/chip_symptoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/widget_appt_chip_pending"
                android:textColor="#CBD5E1"
                android:text="&#9744;  SYMPTOMS" />

        <TextView
                android:id="@+id/chip_meds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/widget_appt_chip_pending"
                android:textColor="#CBD5E1"
                android:text="&#9744;  MEDS LIST" />

        <TextView
                android:id="@+id/chip_report"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/widget_appt_chip_pending"
                android:textColor="#CBD5E1"
                android:text="&#9744;  BLOOD REPORT" />
    </LinearLayout>

</LinearLayout>
